# LLM API Configuration (choose one)

# Option 1: 9router (recommended for free models)
LLM_API_KEY=your-9router-api-key
LLM_BASE_URL=https://9router.com/api/v1
LLM_MODEL=poolside/laguna-m.1:free

# Option 2: OpenRouter
# LLM_API_KEY=sk-or-v1-xxxxx
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=google/gemma-2-9b-it:free

# Option 3: OpenAI
# OPENAI_API_KEY=sk-xxxxx
# LLM_MODEL=gpt-4o

# Database & Logging
DATABASE_PATH=data/blog_automation.db
LOG_FILE=logs/automation.log
DRY_RUN=false

# WordPress Site 1
WP_URL_SITE1=https://yoursite.com
WP_USERNAME_SITE1=your_username
WP_PASSWORD_SITE1=your_app_password
WP_POSTS_PER_DAY_SITE1=2

# WordPress Site 2 (optional)
# WP_URL_SITE2=https://site2.com
# WP_USERNAME_SITE2=user2
# WP_PASSWORD_SITE2=pass2
# WP_POSTS_PER_DAY_SITE2=3

# Encryption key (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=
