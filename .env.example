# ── Claude (Anthropic) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
# Optional model overrides (defaults shown):
# CLAUDE_CONTENT_MODEL=claude-sonnet-4-6
# CLAUDE_ANALYSIS_MODEL=claude-sonnet-4-6

# ── Legacy OpenAI / OpenRouter (optional fallback) ────────────────────────────
# LLM_API_KEY=sk-or-v1-xxxxx
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=google/gemma-2-9b-it:free

# ── Database & Logging ────────────────────────────────────────────────────────
DATABASE_PATH=data/blog_automation.db
LOG_FILE=logs/automation.log
DRY_RUN=false

# ── Encryption (generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ──
ENCRYPTION_KEY=

# ── Google APIs (Search Console + GA4) ───────────────────────────────────────
# Path to your Google service account JSON key file:
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/google-service-account.json
# How many days of history to pull (default 90):
# GSC_DAYS_LOOKBACK=90

# ── Perplexity (optional – GEO citation probing) ─────────────────────────────
# PERPLEXITY_API_KEY=pplx-xxxxx

# ── WordPress Site 1 (moodatingscript) ───────────────────────────────────────
WP_NAME_SITE1=MooDateScript
WP_URL_SITE1=https://moodatingscript.com
WP_USERNAME_SITE1=your_username
WP_PASSWORD_SITE1=your_app_password
WP_POSTS_PER_DAY_SITE1=2
GSC_SITE_URL_SITE1=https://moodatingscript.com/
GA4_PROPERTY_ID_SITE1=123456789

# ── WordPress Site 2 (shaunsocial) ───────────────────────────────────────────
WP_NAME_SITE2=ShaunSocial
WP_URL_SITE2=https://shaunsocial.com
WP_USERNAME_SITE2=your_username
WP_PASSWORD_SITE2=your_app_password
WP_POSTS_PER_DAY_SITE2=2
GSC_SITE_URL_SITE2=https://shaunsocial.com/
GA4_PROPERTY_ID_SITE2=987654321
